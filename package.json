{
    "name": "blocknote-ai-plugin",
    "version": "0.1.0",
    "description": "AI-powered editing commands for BlockNote editors. Streaming, proxy-ready, zero xl-ai dependencies.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./styles.css": "./dist/styles.css"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest --coverage",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "@ai-sdk/openai-compatible": ">=1.0.0",
        "@blocknote/core": ">=0.40.0",
        "@blocknote/react": ">=0.40.0",
        "@floating-ui/react": ">=0.26.0",
        "ai": ">=4.0.0",
        "lucide-react": ">=0.300.0",
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "devDependencies": {
        "@ai-sdk/openai-compatible": "^2.0.30",
        "@blocknote/core": "^0.47.0",
        "@blocknote/react": "^0.47.0",
        "@floating-ui/react": "^0.27.18",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "ai": "^6.0.104",
        "happy-dom": "^20.0.8",
        "lucide-react": "^0.344.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tsup": "^8.4.0",
        "typescript": "^5.5.3",
        "vitest": "^4.0.4"
    },
    "keywords": [
        "blocknote",
        "ai",
        "editor",
        "rich-text",
        "openai",
        "streaming",
        "plugin"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/AdamFarrar/blocknote-ai-plugin.git"
    },
    "author": "Adam Farrar"
}
